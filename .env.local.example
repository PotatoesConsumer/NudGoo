# ─────────────────────────────────────────────────────────────
# NudGoo environment variables
# Copy this file to `.env.local` and fill in the values from your
# Supabase project dashboard (Project Settings → API).
# ─────────────────────────────────────────────────────────────

# Public — safe to expose to the browser. Used by the Supabase client.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Optional — public site URL, used for auth redirects in production.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional — free GIPHY API key for chat GIF search (https://developers.giphy.com).
# Without it, the GIF picker falls back to uploading your own GIF file.
NEXT_PUBLIC_GIPHY_API_KEY=""

# Server-only — NEVER expose to the browser. Used only in trusted server
# contexts (route handlers / server actions) for privileged operations.
# Leave blank unless you add admin-only server logic.
SUPABASE_SERVICE_ROLE_KEY=""
